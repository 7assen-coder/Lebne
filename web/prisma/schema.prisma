generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions Submission[]
  progress    UserProgress[]
}

model PromptItem {
  id           Int      @id @default(autoincrement())
  importId     String   @unique
  sourceText   String
  sourceLocale String
  intent       String
  sourceLabel  String?
  createdAt    DateTime @default(now())

  submissions Submission[]
  progress    UserProgress[]
}

model Submission {
  id          String    @id @default(cuid())
  promptId    Int
  userId      String
  locale      String
  text        String
  status      String    @default("pending") // pending | approved | rejected
  note        String?
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  prompt PromptItem @relation(fields: [promptId], references: [id])
  user   User       @relation(fields: [userId], references: [id])

  @@index([status, createdAt])
  @@index([userId, locale])
  @@index([promptId, locale])
}

/// Tracks that a user has completed (submitted) a prompt for a locale — for progress %.
model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  promptId  Int
  locale    String
  createdAt DateTime @default(now())

  user   User       @relation(fields: [userId], references: [id])
  prompt PromptItem @relation(fields: [promptId], references: [id])

  @@unique([userId, promptId, locale])
  @@index([userId, locale])
}
