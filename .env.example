# --- App ---
LEBNE_ENV=development
LEBNE_LOG_LEVEL=INFO
LEBNE_API_HOST=0.0.0.0
LEBNE_API_PORT=8000

# --- LLM serving (production default: vLLM OpenAI-compatible API) ---
# Local override example: http://localhost:11434/v1 with LEBNE_LLM_PROVIDER=ollama
LEBNE_LLM_PROVIDER=vllm
LEBNE_LLM_BASE_URL=http://localhost:8001/v1
LEBNE_LLM_MODEL=lebne-qwen2.5-3b
LEBNE_LLM_API_KEY=EMPTY
LEBNE_LLM_TEMPERATURE=0.1
LEBNE_LLM_MAX_TOKENS=1024

# --- RAG / Qdrant ---
LEBNE_QDRANT_URL=http://localhost:6333
LEBNE_QDRANT_COLLECTION=lebne_faq
LEBNE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
LEBNE_RAG_TOP_K=5
LEBNE_RAG_SCORE_THRESHOLD=0.55
LEBNE_CHUNK_SIZE=256
LEBNE_CHUNK_OVERLAP=32

# --- Domain guardrail ---
LEBNE_GUARDRAIL_THRESHOLD=0.62
LEBNE_GUARDRAIL_ENABLED=true

# --- Security ---
LEBNE_REQUIRE_AUTH=true
LEBNE_REDACT_PII_IN_LOGS=true
LEBNE_JWT_SECRET=CHANGE_ME_DEV_ONLY_lebne_jwt_secret_32b
LEBNE_SERVICE_JWT_SECRET=CHANGE_ME_DEV_ONLY_lebne_service_secret_32b
LEBNE_JWT_ISSUER=lebne
LEBNE_JWT_AUDIENCE=lebne-api
LEBNE_ACCESS_TOKEN_TTL_SECONDS=3600
LEBNE_STEP_UP_TOKEN_TTL_SECONDS=300
LEBNE_RATE_LIMIT_ENABLED=true
LEBNE_RATE_LIMIT_REQUESTS=60
LEBNE_RATE_LIMIT_WINDOW_SECONDS=60

# Auth: local | hybrid | oidc  (production should use oidc + JWKS)
# Local Keycloak (docker compose): hybrid + URLs below
LEBNE_AUTH_MODE=hybrid
LEBNE_OIDC_JWKS_URL=http://localhost:8080/realms/lebne/protocol/openid-connect/certs
LEBNE_OIDC_ISSUER=http://localhost:8080/realms/lebne
LEBNE_OIDC_AUDIENCE=
LEBNE_OIDC_ALGORITHMS=RS256

# Embeddings: sentence_transformers (prod) | hash (fast local index)
LEBNE_EMBEDDING_BACKEND=hash

# --- Sessions ---
LEBNE_SESSION_BACKEND=memory
LEBNE_REDIS_URL=redis://localhost:6379/0
LEBNE_SESSION_TTL_SECONDS=86400

# --- Wallet backend (same FastAPI app long-term; Flutter talks to /wallet/v1) ---
LEBNE_BACKEND_API_BASE_URL=http://localhost:8000
LEBNE_WALLET_INTERNAL_MODE=true

# --- Database (SQLite local; Postgres in docker-compose) ---
LEBNE_DATABASE_URL=sqlite:///./lebne_wallet.db
# LEBNE_DATABASE_URL=postgresql+psycopg://lebne:lebne@localhost:5432/lebne
